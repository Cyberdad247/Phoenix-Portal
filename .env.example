# Phoenix Portal Environment Variables

# WebSocket Server
NEXT_PUBLIC_WS_URL=wss://ws.phoenixportal.com
NEXT_PUBLIC_SITE_URL=https://phoenixportal.com
WS_PORT=3001

# Redis (Upstash)
UPSTASH_REDIS_URL=your_upstash_redis_url_here

# Shopify (optional)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=your_admin_token_here
SHOPIFY_STOREFRONT_TOKEN=your_storefront_token_here